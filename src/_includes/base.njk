<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "My Blog" }}</title>
<meta name="google-site-verification" content="D3mNQ0k9V6DBLQuJXWDXIWIGvmN51HZ7Ih4zblxHxHk" />
  <meta name="description" content="{{ description or 'A blog about ideas, writing, and things worth thinking about.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-title">
        <span class="title-mark">¶</span>
        <span class="title-text">The Margin of Education</span>
      </a>
      <nav class="site-nav">
        <a href="/mind/">Mind</a>
        <a href="/media/">Media</a>
        <a href="/machines/">Machines</a>
        <a href="/about/">About</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>© <span id="year"></span> — written and built by rubyNcreates.</p>
      <script>document.getElementById('year').textContent = new Date().getFullYear();</script>
    </div>
  </footer>
</body>
</html>
