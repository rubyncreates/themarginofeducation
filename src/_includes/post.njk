---
layout: base.njk
---
<article class="post">
  <div class="container container--narrow">
    <header class="post-header">
      <time datetime="{{ date | htmlDateString }}" class="post-date">{{ date | readableDate }}</time>
      <h1 class="post-title">{{ title }}</h1>
      {% if subtitle %}<p class="post-subtitle">{{ subtitle }}</p>{% endif %}
      {% if category and not hide_category %}
        <p class="post-category-label"><a href="/{{ category | lower }}/">{{ category }}</a></p>
      {% endif %}
    </header>

    <div class="post-content {% if portrait %}has-portrait{% endif %}">
      {% if portrait %}
        <img src="{{ portrait }}" alt="{{ portrait_caption or title }}" class="author-portrait">
      {% endif %}
      {{ content | safe }}
    </div>

    {% if tags and tags.length > 0 %}
      <div class="post-tags">
        <span class="post-tags-label">Tagged:</span>
        {% for tag in tags %}
          {% if tag != "posts" and tag != "mind" and tag != "media" and tag != "machines" %}
            <a href="/tags/{{ tag | slug }}/" class="post-tag">{{ tag }}</a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <footer class="post-footer">
      <a href="/" class="back-link">&larr; Back to all writing</a>
    </footer>
  </div>
</article>
